# Copy this file to .env.deploy.staging and fill in your real values.
# .env.deploy.staging is ignored by git.
#
# This is the deploy config for the *staging* TownSquare instance: a second
# copy of the app running a chosen branch on its own service/port/data dir,
# served behind staging.townsquare.cauenapier.com. Deploy with:
#   scripts/admin/deploy-staging.sh <branch>

# Run the deploy directly on the host (no SSH), like the production local deploy.
DEPLOY_MODE=local

# Keep these distinct from production so staging never touches the live release.
DEPLOY_ROOT=/opt/townsquare-staging
DEPLOY_SERVICE=townsquare-staging.service
DEPLOY_PORT=8789
DEPLOY_OWNER=townsquare:townsquare
HEALTHCHECK_URL=https://staging.townsquare.cauenapier.com/healthz

# For a remote staging host instead, mirror .env.deploy.example:
# DEPLOY_MODE=remote
# DEPLOY_HOST=your-server.example.com
# DEPLOY_USER=deploy
# SSH_OPTS='-o BatchMode=yes'

# App runtime secrets/flags belong in the staging service's own env file on the
# server (see ops/systemd/townsquare-staging.service), NOT here. The staging
# instance must run with:
#   ENABLE_STAGING_PAGE=1   -> serves /staging
#   DATA_DIR=/opt/townsquare-staging/data   -> separate registry from production
