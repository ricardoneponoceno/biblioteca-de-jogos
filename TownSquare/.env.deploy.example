# Copy this file to .env.deploy.local and fill in your real values.
# .env.deploy.local is ignored by git.

DEPLOY_HOST=your-server.example.com
DEPLOY_USER=deploy
DEPLOY_MODE=remote
DEPLOY_ROOT=/opt/townsquare
DEPLOY_SERVICE=townsquare.service
DEPLOY_PORT=8787
DEPLOY_OWNER=townsquare:townsquare
HEALTHCHECK_URL=https://your-domain.example/townsquare-healthz
SSH_OPTS='-o BatchMode=yes'

# App runtime secrets belong in an uncommitted env file on the server, for example:
# TELEGRAM_BOT_TOKEN=123456:replace-me
# TELEGRAM_CHAT_ID=123456789
# LANDING_ORIGIN=https://your-landing-domain.example
# PLAUSIBLE_DOMAIN=your-domain.example
#
# Inactive visitor cleanup (also supported in the server checkout's .env):
# INACTIVE_DISCONNECT_MS=1800000
# INACTIVE_CHECK_INTERVAL_MS=60000
